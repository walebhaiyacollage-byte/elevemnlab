# LiveKit Credentials (https://cloud.livekit.io/)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Deepgram (STT & TTS)
# Sign up at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_key

# Groq (LLM)
# Sign up at https://console.groq.com/
GROQ_API_KEY=your_groq_key
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile

# Eleven Labs (TTS)
# Sign up at https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=Rachel
ELEVENLABS_MODEL=eleven_monolingual_v1

# Vobiz / SIP Trunking Configuration
VOBIZ_SIP_TRUNK_ID=your_trunk_id
OUTBOUND_TRUNK_ID=your_trunk_id
VOBIZ_SIP_DOMAIN=your_sip_domain
VOBIZ_USERNAME=your_sip_username
VOBIZ_PASSWORD=your_sip_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# TTS Provider Configuration
TTS_PROVIDER=elevenlabs